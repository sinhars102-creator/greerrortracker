# Supabase — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic — console.anthropic.com -> API Keys
# Server-side only. Never prefix this with NEXT_PUBLIC_ or it'll ship to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional manual fallback provider (see lib/gemini.js) — switch AI_PROVIDER
# to "gemini" when Anthropic credits run out, unset/"anthropic" to switch back.
# GEMINI_API_KEY — aistudio.google.com/apikey
# AI_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-flash-latest