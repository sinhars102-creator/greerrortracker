# Supabase — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic — console.anthropic.com -> API Keys
# Server-side only. Never prefix this with NEXT_PUBLIC_ or it'll ship to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional alternate providers, switchable on-screen (header dropdown, see
# lib/settings.js/app_settings table) or forced locally via AI_PROVIDER.
# AI_PROVIDER=gemini | groq

# Gemini (see lib/gemini.js) — aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-flash-latest

# Groq (see lib/groq.js) — console.groq.com/keys — text-only, no vision
# model on a standard key, so image/document calls stay on Anthropic even
# when Groq is selected.
# GROQ_API_KEY=...
# GROQ_MODEL=llama-3.3-70b-versatile