{
  "manifest_version": 3,
  "name": "GRE Mistake Capture",
  "version": "1.0.0",
  "description": "Screenshot a hard GRE question and auto-log it to the GRE Error Ledger.",
  "key": "",
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_title": "GRE Capture" },
  "permissions": ["activeTab", "storage", "notifications"],
  "host_permissions": [
    "https://gre-tracker-web.vercel.app/*",
    "http://localhost:3000/*",
    "https://vflxwdetwxzxsybsganv.supabase.co/*"
  ],
  "externally_connectable": {
    "matches": ["https://gre-tracker-web.vercel.app/*", "http://localhost:3000/*"]
  },
  "commands": {
    "capture-question": {
      "suggested_key": { "default": "Ctrl+Shift+G", "mac": "Command+Shift+G" },
      "description": "Capture the current tab as a new GRE mistake"
    }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
